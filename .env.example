# Kerala Health Portal — environment template
# Copy to .env and fill real values. NEVER commit .env (git-ignored).
# Phase 0: placeholders only. No real secrets here.

# Database
DATABASE_URL=

# Redis
REDIS_URL=

# Auth (real OTP/JWT — Task 3.0)
JWT_SECRET=
JWT_REFRESH_SECRET=
AUTH_PEPPER=
# Dev only: surface OTP codes in the API response instead of SMS. NEVER set in prod.
AUTH_OTP_DEBUG=

# SMS Gateway (Kerala primary; Twilio fallback)
OTP_SMS_GATEWAY_URL=
OTP_SMS_API_KEY=

# Email (AWS SES — transactional only)
SES_SMTP_HOST=
SES_SMTP_USER=
SES_SMTP_PASS=

# AI (Anthropic — Haiku model only)
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-20241022

# App
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_DEFAULT_LOCALE=ml

# Portal (DEV ONLY) — stand-ins for the authenticated provider until Phase 2 auth.
PORTAL_DEMO_DOCTOR_ID=
PORTAL_DEMO_HOSPITAL_ID=

# Storage (AWS S3 or Cloudflare R2)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
