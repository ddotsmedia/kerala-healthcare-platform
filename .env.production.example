# Kerala Health Portal — production env template.
# Copy to .env.production and fill in real values. NEVER commit .env.production.
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Database (compose service name khp-postgres; host access via 127.0.0.1:5440)
DATABASE_URL=postgres://khp:POSTGRES_PASSWORD@khp-postgres:5432/khp

# Redis (compose service name khp-redis; host access via 127.0.0.1:6380)
REDIS_URL=redis://:REDIS_PASSWORD@khp-redis:6379

# Auth secrets (64-byte hex for JWT, 32-byte hex for the rest)
JWT_SECRET=
JWT_REFRESH_SECRET=
AUTH_PEPPER=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# AI
ANTHROPIC_API_KEY=

# SMS gateway (OTP + notifications)
OTP_SMS_GATEWAY_URL=
OTP_SMS_API_KEY=

# Email (SES SMTP)
SES_SMTP_HOST=
SES_SMTP_USER=
SES_SMTP_PASS=

# Public URLs
NEXT_PUBLIC_APP_URL=https://malayalidoctor.com
NEXT_PUBLIC_PORTAL_URL=https://portal.malayalidoctor.com
NEXT_PUBLIC_ADMIN_URL=https://admin.malayalidoctor.com
NEXT_PUBLIC_DEFAULT_LOCALE=ml
